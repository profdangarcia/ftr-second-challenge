{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "lib": ["es2023", "dom"],
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "prisma/**/*"]
}
